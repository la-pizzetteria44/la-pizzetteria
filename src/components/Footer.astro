---
import { Phone, Map} from "@lucide/astro";

const { formattedDays } = Astro.props;
---

<footer class="footer">

    <div class="footer-main">

        <!-- IDENTITÉ -->
        <div class="footer-block">
            <h3>La Pizzetteria</h3>
            <p>3 Avenue de la Vendée, 44140 Aigrefeuille-sur-Maine</p>

            <a href="tel:0228028829" class="footer-phone">
            <Phone size={18} />
            <span>02 28 02 88 29</span>
            </a>

            <a href="https://maps.google.com/?q=La+Pizzetteria" target="_blank" class="footer-map">
            Itinéraire
            </a>
        </div>

        <!-- HORAIRES -->
        <div class="footer-block">
            <h4>Horaires</h4>

            {formattedDays.map((d: { day: string | any[]; value: unknown; }) => (
                <p class="footer-hours">
                <strong>{d.day.slice(0,3)}</strong> — {d.value}
            </p>
            ))}
        </div>

        <!-- NAV -->
        <div class="footer-block">
            <h4>Navigation</h4>
            <a href="home">Accueil du site</a>
            <a href="menu">Nos produits</a>
            <a href="visit">Venir chez nous</a>
        </div>

        <!-- BOTTOM -->
        <div class="footer-bottom">
            <p>© 2026 La Pizzetteria</p>
            <div class="footer-legal">
                <a href="legal">Mentions légales</a>
                <a href="policy">Confidentialité</a>
            </div>
            <p class="credit">Site réalisé par Romain Fournier</p>
        </div>

        <div class="sticky-cta">
                <a href="tel:0123456789"  class="cta call">
                    <Phone size={18} /> Commander
                </a>
                      
                <a href="https://maps.google.com/?q=La+Pizzetteria" target="_blank" class="cta map">
                    <Map size={18} /> Itinéraire
                </a>
        </div>

</footer>

<style>
.footer {
  background: #111;
  color: #fff;
  margin-top: 3rem;
  padding: 2rem 1rem 0.8rem;
}

.footer-main {
  display: flex;
  flex-direction: column;
  gap: 2.5rem;
    background: rgba(255,255,255,0.02);
  padding: 1rem;
  border-radius: 12px;
}

.footer-block {
  padding-bottom: 1rem;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}

.footer-block:last-child {
  border-bottom: none;
}

.footer-block h3 {
  font-size: 1.6rem;
}

.footer-block h4 {
  font-size: 1.4rem;
  color: #fff;
}


.footer-block h3,
.footer-block h4 {
  margin-bottom: 0.5rem;
}

.footer-block p {
  color: #d1d5db;
  font-size: 1.3rem;
}

/*  TEL */
.footer-phone {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-top: 0.5rem;
  color: #fff;
  text-decoration: none;
  font-weight: 600;
}

/* MAP */
.footer-map {
  display: inline-block;
  margin-top: 0.7rem;
  background: rgba(230,57,70,0.1);
  padding: 6px 10px;
  border-radius: 8px;
}

/* LINKS */
.footer-block a {
  display: block;
  margin: 0.3rem 0;
  color: #d1d5db;
  text-decoration: none;
}

.footer-block a:hover {
  color: #fff;
}

.footer-hours {
  font-size: 1.4rem;
}

/* BOTTOM */
.footer-bottom {
  margin-top: 2rem;
  padding-top: 1rem;
  text-align: center;
  font-size: 1.4rem;
  color: #9ca3af;
}

.footer-legal {
  display: flex;
  justify-content: center;
  gap: 1rem;
  margin: 0.5rem 0;
}

.credit {
  margin-top: 0.5rem;
  opacity: 0.7;
}

.sticky-cta {    
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  display: flex;
  z-index: 9999;
  background: #111;
  border-top: 1px solid #333;
}

.sticky-cta a {
    text-decoration: none;
    color: #fff;
}

/* Boutons */
.sticky-cta .cta {
  flex: 1;
  text-align: center;
  padding: 1rem;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
}

/* Call */
.sticky-cta .call {
  background: #e63946;
}

/* Map */
.sticky-cta .map {
  background: #1f2937;
  color: #fff;
}

/* Hover léger */
.sticky-cta .cta:active {
  transform: scale(0.97);
}

.footer-main {
  max-width: 600px;
  margin: 0 auto;
  padding: 0 1rem;
}

.footer-bottom {
  max-width: 600px;
  margin: 0 auto;
  padding: 1 1rem;
}

.footer-bottom p:first-child {
  padding-bottom: 0;

}

.footer-block:first-child {
  text-align: center;
}

.footer-phone {
  justify-content: center;
}

.footer-map {
  margin-left: auto;
  margin-right: auto;
}

.footer-legal a {
    text-decoration: underline;
    color: #9ca3af;
}

@media (min-width: 768px) {
  .footer-main {
    flex-direction: row;
    justify-content: space-between;
  }

  .footer-block {
    flex: 1;
  }

  .footer-bottom {
    text-align: center;
  }
}

</style>