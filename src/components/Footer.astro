---
import { Phone } from "@lucide/astro";
import FBLogo from "../../public/images/Facebook_Logo.png";

import Map from "./sections/Map.astro";

const { formattedDays } = Astro.props;
---

<footer class="footer">

    <div class="footer-main">

        <!-- IDENTITÉ -->
        <div class="footer-block">
            <h3>La Pizzetteria</h3>
            <p>3 Avenue de la Vendée, 44140 Aigrefeuille-sur-Maine</p>

            <a href="tel:0228028829" class="footer-phone">
            <Phone size={18} />
            <span>02 28 02 88 29</span>
            </a>
            <Map />
        </div>

        <!-- HORAIRES -->
        <div class="footer-block">
            <h3>Horaires</h3>
            <table class="footer__hours">
                <tbody>
                    {formattedDays.map((d: { day: string | any[]; value: unknown; }) => (
                        <tr>
                            <th>{d.day}</th>
                            <td>{d.value}</td>
                        </tr>
                    ))}

                </tbody>
            </table>
            <!-- {formattedDays.map((d: { day: string | any[]; value: unknown; }) => (
                <p class="footer-hours">
                <strong>{d.day.slice(0,3)}</strong> — {d.value}
            </p>
            ))} -->
        </div>

        <!-- NAV -->
        <div class="footer-block">
            <h3>Navigation</h3>
            <a href="home">Accueil du site</a>
            <a href="menu">Nos produits</a>
            <a href="visit">Venir chez nous</a>
        </div>

        <!-- SOCIAL -->
        <div class="footer__social">
            <a
                href="https://www.facebook.com/lapizzetteria44/"
                target="_blank"
                rel="noopener noreferrer"
                title="Aller sur notre page facebook"
                class="social-link"
                >
                <img src={FBLogo.src} alt="Logo de Facebook" class="social__icon"/>
            </a>
        </div>

        <!-- BOTTOM -->
        <div class="footer-bottom">
            <p>© 2026 La Pizzetteria</p>
            <div class="footer-legal">
                <a href="legal">Mentions légales</a>
                <a href="policy">Confidentialité</a>
            </div>
            <p class="credit">Site réalisé par Romain Fournier</p>
        </div>

        

</footer>

