---
import logo from "../../public/images/logo.png";
import { Phone, Menu } from '@lucide/astro';

import hours from '../content/hours/hours.json';
---

<header class="header">

    <div class="header__logo">
        <a href="/">
            <img 
                src={logo.src}
                alt="Logo de la pizzetteria"
                class="header__logo-img"
            />
        </a>
    </div>

    <a href="#openHours" class="header__status" title="voir nos horaires" data-hours={JSON.stringify(hours)}>
            <span class="header__status-text">Chargement...</span>
    </a>

    <div class="header__call">
        <a href="tel:0228028829" class="header__call-link" title="Nous appeler" aria-label="Appeler la pizzetteria">
            <Phone class="header__call-icon" size={20} />
            <span class="header__call-text">Commander</span>
        </a>
    </div>

    <!-- Burger toggle (no JS) -->
    <input type="checkbox" id="nav-toggle" class="header__toggle" />
    <label for="nav-toggle" class="header__burger">
        <!-- <Menu size={24} /> -->
        <span></span>
        <span></span>
        <span></span>
    </label>
    <div class="header__overlay"></div>


    <nav class="header__nav">
        <a href="/" class="header__link">Accueil</a>
        <a href="/#" class="header__link">Menu</a>
        <a href="/#" class="header__link">Contact</a>
    </nav>

    

</header>

<script>
function getStatus(hours: any) {
  const now = new Date();

  const daysOrder = [
    "dimanche","lundi","mardi","mercredi","jeudi","vendredi","samedi"
  ];

  const todayKey = daysOrder[now.getDay()];
  const today = hours[todayKey];

  if (!today || today.closed || !today.slots?.length) {
    return { label: "Fermé", open: false };
  }

  const currentMinutes = now.getHours() * 60 + now.getMinutes();

  let isOpen = false;
  let nextOpen = null;
  let currentClose = null;

  for (const slot of today.slots) {
    const openMinutes =
      parseInt(slot.open.hour) * 60 + parseInt(slot.open.minute);

    const closeMinutes =
      parseInt(slot.close.hour) * 60 + parseInt(slot.close.minute);

    // ✅ actuellement ouvert
    if (currentMinutes >= openMinutes && currentMinutes <= closeMinutes) {
      isOpen = true;
      currentClose = slot.close;
      break;
    }

    // ⏳ prochain créneau aujourd’hui
    if (currentMinutes < openMinutes && !nextOpen) {
      nextOpen = slot.open;
    }
  }

  // 🎯 Cas 1 → ouvert maintenant
  if (isOpen && currentClose) {
    return {
      label: `Ouvert · ferme à ${currentClose.hour}:${currentClose.minute}`,
      open: true
    };
  }

  // 🎯 Cas 2 → fermé mais ouvre plus tard aujourd’hui
  if (nextOpen) {
    return {
      label: `Fermé · ouvre à ${nextOpen.hour}:${nextOpen.minute}`,
      open: false
    };
  }

  // 🎯 Cas 3 → fermé toute la journée
  return {
    label: "Fermé",
    open: false
  };
}

const statusEl = document.querySelector<HTMLElement>(".header__status");

if (statusEl) {
  const status = getStatus(statusEl.dataset.hours ? JSON.parse(statusEl.dataset.hours) : {});

  statusEl.textContent = status.label;

  statusEl.classList.toggle("is-open", status.open);
  statusEl.classList.toggle("is-closed", !status.open);
}
</script>