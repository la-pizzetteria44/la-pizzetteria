---
import logo from "../../public/images/logo.png";
import { Phone } from '@lucide/astro';
---

<header>
	<div class="top-header">

        <div class="logo">

            <h1>
                <a href="/">
                    <img
					src={logo.src}
					alt="Logo de la pizzetteria"
                    />
                </a>
            </h1>
        </div>
		<a href="#openHours" title="voir nos horaires">
			Fermé
		</a>

		<p>
			<a href="tel:0228028829" class="phone"><Phone color="#fff" size={20}/><span>: 02 28 02 88 29</span></a>
			<a href="tel:0228028829" title="nous appeler">
				
			</a>
		</p>

		<div class="social">
            <a
				href="https://www.facebook.com/lapizzetteria44/"
				target="_blank"
				title="aller sur notre page facebook">
				<!-- Facebook SVG -->
				<svg width="20" height="20" viewBox="0 0 24 24">
					<path fill="currentColor" d="M12 2.04C6.5 2.04 2 6.54 2 12.04c0 5 3.7 9.1 8.5 9.9v-7h-2.6v-2.9h2.6V9.4c0-2.6 1.5-4 3.8-4c1.1 0 2.2.2 2.2.2v2.4h-1.3c-1.3 0-1.7.8-1.7 1.6v1.9h2.9l-.5 2.9h-2.4v7c4.8-.8 8.5-4.9 8.5-9.9c0-5.5-4.5-10-10-10Z"/>
				</svg>
			</a>
		</div>
	</div>

	<!-- <div class="bottom-header">
		

		<nav>
			<a href="/our-story">Notre histoire</a>
		</nav>
	</div> -->
</header>

<style>
    header {
	background-color: #fff;
    position: sticky;
    top: 0;
    z-index: 9999;

    }
	.top-header {
		background-color: var(--color-green);
		color: #fff;
        padding: 0.6rem 1rem ;
		display: flex;
		justify-content: space-between;
        align-items: center;
		gap: 1.5rem;
	}

    	.top-header p{
		padding: 0;
	}
    
    .logo {
        width: 45px;
        margin: 0;
    }
    h1{
        margin: 0;
    }
	.social {
		display: flex;
		gap: 3rem;
	}
	
	img {
		width: 100%;
		height: auto;
		border-radius: 50%;
		box-shadow: 1px 1px 1px 2px #a9a8a8;
	}

	svg,
	a {
		color: #fff;
	}

    .phone {
    color: #fff;
    font-weight: 600;
    display: flex;
    text-decoration: none;
    }

    .phone span {
        margin-left: 0.5rem;
        align-self: flex-end;
    }


</style>