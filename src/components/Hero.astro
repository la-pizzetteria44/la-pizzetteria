---
import { Phone } from '@lucide/astro';
const { infos } = Astro.props;
---
<!-- HERO -->
    <section class="hero">
        <div class="bcg_hero">
            <img src={infos.cover_image} alt="Restaurant - cuisine maison" />
            <div class="header_hero">
                <h1>{infos.title}</h1>
                <p>{infos.description}</p>
            </div>
            <div class="cta_hero">
                <a href="tel:0123456789" class="btn-cta primary"><Phone color="#fff" size={24}/><span>Réserver</span></a>
                <a href="#plats" class="btn-cta secondary">Voir la carte</a>
            </div>
        </div>
    </section>

    <style>
        .hero {
            margin-top: 0;
            position: relative; 
        }
        
        .hero::after {
            content: "";
            position: absolute;
            inset: 0;
            background:linear-gradient(
            to bottom,
            rgba(0, 0, 0, 0.341) 0%,
            rgba(0, 0, 0, 0.142) 100%
            );
            z-index: 555;
        }

        .bcg_hero img {
            width: 100%;
        }

        .bcg_hero {
            position: relative;
            display: flex;
            flex-direction: column;
        }

        .bcg_hero .header_hero {
            position: absolute;
            top: 0%;
            left: 50%;
            width: 100%;
            transform: translate(-50%, 0);
            padding: 0.5rem;
            margin-top: 0;
            text-align: center;
            z-index: 999;
            color: #fff;
        }

        .cta_hero {
            position: absolute;
            top: 70%;
            left: 50%;
            transform: translate(-50%, -50%);
            display: flex;
            gap: 2rem;
            z-index: 999;
        }

        .cta_hero a {
            border-radius: 12px;
            color: #fff;
            font-weight: 600;
            padding: 0.5rem;
            display: inline-block;
            width: 120px;
            text-decoration: none;
            text-align: center;
        }

        .cta_hero a:hover {
            background-color: var(--color-primary-hover);
        }

        .cta_hero .btn-cta{
            display: inline-flex;
            align-items: center;   /* centre vertical */
            justify-content: center; /* centre horizontal */
            gap: 8px;              /* espace entre icône et texte */

            /* padding: 12px 20px; */
            color: white;
          
            /* border-radius: 8px; */
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .cta_hero .btn-cta:hover {
            background: var(--color-primary-hover);
            transform: translateY(-1px);
        }

        .btn-cta.primary {
            background:  #e63946;
            border: none;
        }
        .btn-cta.secondary {
            /* background: rgba(0, 0, 0, 0.334); */
            border: 1.5px solid rgba(255,255,255,0.6);
            background: rgba(255,255,255,0.15);
            backdrop-filter: blur(2px);
        }
    </style>