---
import "../styles/sections/hero.css";
import { Phone } from '@lucide/astro';

const { infos, special } = Astro.props;
---

<section class="hero">
    <div class="hero__top">
            <div class="hero__content">
            {
                special?.enabled && (
                    <div class="hero__warning">
                        <p class="hero__warning__text">{special.content}</p>
                        <hr class="hero__warning__divider" />
                    </div>
                )
            }
            
            <h1 class="hero__title">{infos.title}</h1>
            <p class="hero__subtitle">· {infos.subtitle} ·</p>
        </div>
            
    </div>
    <div class="hero__img">
        <img class="hero__img" src={infos.cover_image} alt="Restaurant - cuisine maison"  loading="eager" fetchpriority="high"/>

    </div>
    <div class="hero_bottom">
        <div class="cta hero__cta">
                <a href="tel:0228028829" class="btn btn--primary" title="Nous appeler" aria-label="Appeler la pizzetteria"><Phone size={24}/>
                    <span>Commander</span>
                </a>
                <a href="/menu" class="btn btn--secondary">
                    <span>Voir le menu</span>
                </a>
            </div>
    </div>        
  
</section>
