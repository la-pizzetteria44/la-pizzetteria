---
import { Pizza, Phone, Flame } from '@lucide/astro';

const {dishOfTheMoment} = Astro.props;
---

<!-- 🔥 PLAT DU MOMENT -->
    {dishOfTheMoment && (
    <section class="highlight">
        <h2>Pizza du moment</h2>

        <article class="highlight-card">
            <div class="info">
                <p><Flame size={24}/> Suggestion du chef <Flame size={24}/></p>
            </div>
            <img src={dishOfTheMoment.image} alt={dishOfTheMoment.name} />

            <div class="content">
                <h3>{dishOfTheMoment.name}</h3>

                <p class="ingredient">
                    {dishOfTheMoment.ingredients?.join(", ")}
                </p>
                
                <div class="footer_content">
                    <p class="price">
                        {dishOfTheMoment.price.toFixed(2)}€
                    </p>
                    <div class="cta cta_card">

                        <a href="tel:0123456789" class="btn-cta primary"><Phone size={24}/><span>Commander</span></a>
                        <a href="/menu" class="btn-cta secondary">Voir le menu</a>
                    </div>
                </div>
            </div>
        </article>
    </section>
    )} 

<style>


.highlight {
	background: linear-gradient(135deg, #FFF7ED, #FFEDD5);
	padding: 2rem 1rem;
	text-align: center;
}

.highlight-card {
    position: relative;
	max-width: 500px;  
	margin: auto;
	background: white;
	border-radius: 1rem;
	overflow: hidden;
	box-shadow: 0 10px 25px rgba(0,0,0,0.1);
}

.highlight .info {
    background-color: #fff;
    color: var(--color-red);
    font-weight: bold;
    padding-top: 0.9rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
}

.info svg {
    stroke: var(--color-red);
    vertical-align: text-bottom;
}

.highlight-card img {
	max-width: 100%;
    max-height: 300px;
    display: block;
}

.highlight-card .content {
	padding: 1rem;
}

.highlight h2, .highlight h3 {
    margin-top: .5rem;
	font-size: 2rem;
	/* color: #1F2937; */
}

.highlight h3 {
    color: #e6450b;
}

.highlight .price {
	font-size: 1.8rem;
    font-weight: bold;
    color: var(--color-green);
}

/* .btn-cta.primary svg{
    stroke: var(--color-red);
} */

.cta .btn-cta {
    color: #333;
}
.cta .btn-cta:hover, .cta .btn-cta:hover svg {
    color: #fff;
    stroke: #fff;
}

.cta .btn-cta.primary {   
    box-shadow: 0 1px 5px var(--color-red);
    opacity: 0.9;
}
.cta .btn-cta.secondary {   
    box-shadow: 0 2px 5px rgba(34, 197, 94, 0.4);
}
.cta .btn-cta.secondary:hover { 
    background-color: var(--color-green);  
    box-shadow: 0 2px 5px rgba(34, 197, 94, 0.4);
}

.info{
    background: rgba(0,0,0,0.05);
    padding: 0.5rem 1rem;
    font-size: 1.4rem;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 1px;
}
</style>