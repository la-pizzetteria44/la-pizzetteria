---
import "../../styles/sections/highlight.css";

import { Phone, Flame } from '@lucide/astro';

const {dishOfTheMoment} = Astro.props;
---

<!-- 🔥 PLAT DU MOMENT -->
    {dishOfTheMoment && (
    <section class="highlight">
        <h2 class="highlight__title">
            <span class="highlight__title-inner">
                <Flame size={24} />
                <span>Notre pizza du moment</span>
                <Flame size={24} />
            </span>
        </h2>

        <article class="card highlight__card">
            
            <img class="highlight__img" src={dishOfTheMoment.image} alt={dishOfTheMoment.name} fetchpriority="high"loading="eager" width="400" height="300"/>

            <div class="highlight__content">
                <h3>{dishOfTheMoment.name}</h3>

                <p class="highlight__ingredients">
                    Base {dishOfTheMoment.base.replaceAll("-", " ")} · {dishOfTheMoment.ingredients.flat().map((i) => i.trim()).join(" · ")}
                </p>
                
                <p class="highlight__price">
                    {dishOfTheMoment.price.toFixed(2)}€
                </p>
                
                <div class="cta highlight__cta">
                    {/* <a href="tel:0228028829" class="btn btn--primary" title="Nous appeler" aria-label="Appeler pour commander une pizza"><Phone size={24}/>
                        <span>Commander</span>
                    </a> */}
                    <a href="/menu" class="btn btn--secondary">
                        <span>Voir le menu</span>
                    </a>
                </div>
            </div>
        </article>
    </section>
    )} 

