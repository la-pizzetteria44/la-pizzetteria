---
import "../styles/base/reset.css";
import "../styles/base/variables.css";
import "../styles/base/global.css";
import "../styles/base/typography.css";

import "../styles/sections/hero.css";
import "../styles/sections/highlight.css";
import "../styles/sections/selection.css";
import "../styles/sections/presentation.css";

import "../styles/components/card.css";
import "../styles/components/filter.css";
import "../styles/sections/review.css";
import "../styles/layout.css";

import infos from '../content/infos.json';


---
<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/apple-touch-icon.png" />
		<link
			rel="icon"
			type="image/png"
			sizes="32x32"
			href="/favicon-32x32.png" />
		<link
			rel="icon"
			type="image/png"
			sizes="16x16"
			href="/favicon-16x16.png" />
		<link rel="manifest" href="/site.webmanifest" />

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap">
        
        <link rel="canonical" href={infos.site_url} />

		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <meta property="og:locale" content="fr_FR" />
        <meta property="og:url" content={infos.site_url} />
        <meta property="og:title" content={infos.title} />
        <meta property="og:description" content={infos.description} />
        <meta property="og:type" content="website" />
        <meta property="og:image" content=`${infos.site_url}${infos.cover_image}` />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={infos.title} />
        <meta name="twitter:description" content={infos.description} />
        <meta name="twitter:image" content=`${infos.site_url}${infos.cover_image}` />
        <meta name="theme-color" content="#EA580C" />
        <meta name="description" content={infos.description} />
        <meta name="apple-mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-status-bar-style" content="default">
        <meta name="format-detection" content="telephone=no">
        <meta name="apple-mobile-web-app-title" content={infos.title}>

		<title>{infos.title} - {infos.city}</title>
	</head>
	<body>
        <slot />
        

<script is:inline>
  if (typeof window !== "undefined") {
    const script = document.createElement("script");
    script.src = "https://identity.netlify.com/v1/netlify-identity-widget.js";
    document.body.appendChild(script);

    script.onload = () => {
      if (window.netlifyIdentity) {
        window.netlifyIdentity.init();

        window.netlifyIdentity.on("login", () => {
          window.location.href = "/admin/";
        });

        const params = new URLSearchParams(window.location.search);
        if (params.has("invite_token") || params.has("recovery_token")) {
          window.netlifyIdentity.open();
        }
      }
    };
  }
</script>

	</body>

</html>



<style is:global>

.cta .btn-cta {
    color: #333;
    border: none;
}
.cta .btn-cta:hover, .cta .btn-cta:hover svg {
    color: #fff;
    stroke: #fff;
}

.cta .btn-cta.primary {   
    box-shadow: 0 1px 5px #333;
    color: var(--color-red);
}
.cta .btn-cta.secondary {   
    box-shadow: 0 2px 5px  #333;
    /* color: var(--color-green); */
}
.cta .btn-cta.secondary:hover { 
    background-color: var(--color-green);  
    box-shadow: 0 2px 5px rgba(34, 197, 94, 0.4);
}

    

/* 🔥 NAV */
.menu-nav {
	position: sticky;
	top: 50px;
	background: #fff;
	display: flex;
	justify-content: center;
	gap: 1rem;
	padding: 1rem;
	border-bottom: 1px solid #e5e7eb;
	z-index: 10;
    color: #1F2937;
}

.menu-nav a {
	text-decoration: none;
	font-weight: bold;
	color: #333;
}

.nav-link {
  position: relative;
  text-decoration: none;
  color: black;
}

.nav-link::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -4px;
  width: 0%;
  height: 2px;
  background: #e63946;
  transition: width 0.3s ease;
}

.nav-link:hover::after {
  width: 100%;
}

.nav-link.active {
  color: #e63946;
}

.nav-link.active::after {
  width: 100%;
}


.btn-cta.primary {
    background:  #e63946;
    border: none;
}
.btn-cta.secondary {
    border: 1.5px solid rgba(255,255,255,0.6);
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(2px);
}



 #map {
        margin-top: 2rem;
        display: flex;
        justify-content: center;
        flex-direction: column;
    }

    #map iframe {
        border: none;
        border-radius: 12px;
        width: 100%;
        max-width: 600px;
        height: 300px;
    }

    #map a {
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
        font-weight: bold;
        margin-top: 1rem;  
        padding-right: 1rem; 
        color: #333;
        text-align: right;

    }

    #map a:hover {
        text-decoration: underline;
    }

    button.active svg {
    transform: scale(1.1);
}

/* POLICY-LEGAL */
.policy-legal {
    padding: 4rem 1.5rem;
    background: #fafafa;
    max-width: 750px;
    margin: 0 auto;
    color: #222;
    font-family: system-ui, sans-serif;
    line-height: 1.7;
}


/* TITRE PRINCIPAL */
.policy-legal h1 {
  font-size: 2.5rem;
  margin-bottom: 2rem;
  text-shadow: none;
}

/* SECTIONS */
.policy-legal section {
  margin-bottom: 2rem;
}

/* TITRES */
.policy-legal h2 {
  font-size: 1.7rem;
  margin-bottom: 0.5rem;
  margin-top: 1.5rem;
}

/* TEXTE */
.policy-legal p {
  margin: 0.5rem 0;
}

/* LIENS */
.policy-legal a {
  color: #000;
  text-decoration: underline;
}

.policy-legal a:hover {
  opacity: 0.7;
}

/* RESPONSIVE */


  
</style>
