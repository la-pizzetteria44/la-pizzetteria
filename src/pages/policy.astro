---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import hours from '../content/hours/hours.json';

function formatDay(day: { closed: any; slots?: any[]; }) {
  if (!day || day.closed) return "fermé";

  if (!day.slots || day.slots.length === 0) return "fermé";

  return day.slots
    .map((slot: { open: { hour: any; minute: any; }; close: { hour: any; minute: any; }; }) =>
      `${slot.open.hour}:${slot.open.minute}-${slot.close.hour}:${slot.close.minute}`
    )
    .join(" / ");
}

const daysOrder = [
  "lundi","mardi","mercredi","jeudi","vendredi","samedi","dimanche"
];

const formattedDays = daysOrder.map(dayKey => {
  const day = hours[dayKey as keyof typeof hours] ?? { closed: true };

  return {
    day: dayKey,
    value: formatDay(day)
  };
});

---

<Layout title="Politique de confidentialité">
<main class="policy-legal">

        <h1>Politique de confidentialité</h1>
        
        <p>Ce site ne collecte aucune donnée personnelle.</p>
        
        <p>Aucun cookie de suivi ou de mesure d’audience n’est utilisé.</p>
        
        <p>Les seules données éventuellement transmises le sont directement par l’utilisateur (appel téléphonique, email).</p>
        
        

</main>
<Footer formattedDays={formattedDays} />
</Layout>

 